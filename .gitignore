# Root .gitignore for NasProxy multi-module Maven project

# Maven build outputs
/target/
**/target/
/.m2/
/.it-cache/

# Gradle/other build outputs (in case)
/out/
/build/

# IDE files
/.idea/
**/*.iml
/.vscode/
/.settings/
/.classpath
/.project

# Logs
/logs/
**/*.log

# OS/system files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*.orig

# Local reference checkouts
.refenrence/

# Compiled classes
**/*.class

# Keep Maven Wrapper scripts and directory (do not ignore)
.mvn/
mvnw
mvnw.cmd

# Node (if any submodule uses it later)
/node_modules/
**/node_modules/
/.npm/

# Local GeoIP databases for private Docker image builds
/data/geoip/*.mmdb
/data/geoip/*.mmdb.gz

# Dist artifacts outside target (optional)
# /dist/
# **/*.zip
# **/*.tar.gz
# Spring Boot static build artifacts
/backend/control-manager/src/main/resources/static/
/backend/proxy-worker/target/it-xray/
